# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Service Configuration
# Provider options: mailersend | smtp | console
EMAIL_PROVIDER=mailersend

# MailerSend Configuration (when EMAIL_PROVIDER=mailersend)
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=Your App Name

# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# Supports Gmail, Outlook, and custom SMTP servers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Your App Name
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Application Configuration
APP_NAME=Antigravity
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:5001
BRAND_LOGO_URL=https://wjdncjhlpioohrjkamqw.supabase.co/storage/v1/object/public/brand-assets/brand-logo.png
PORT=5001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
TRUST_PROXY=false
CRON_SECRET=replace-with-a-random-secret-for-scheduled-jobs
ENABLE_INTERNAL_SCHEDULER=true
ENABLE_RESERVATION_CLEANUP=true
LOG_PROVIDER=file
NEW_RELIC_ENABLED=false
NEW_RELIC_HOST=collector.newrelic.com
NEW_RELIC_LICENSE_KEY=your_new_relic_license_key
NEW_RELIC_APP_NAME=Antigravity
NEW_RELIC_LOG_LEVEL=info
INVOICE_STORAGE_STRATEGY=BOTH
JSON_BODY_LIMIT=2mb
URLENCODED_BODY_LIMIT=1mb
GENERIC_UPLOAD_FILE_SIZE_LIMIT_MB=10
ABOUT_TEAM_IMAGE_LIMIT_MB=5
PRODUCT_LIST_CACHE_TTL_MS=30000
CART_CACHE_TTL_MS=3000
CHECKOUT_SUMMARY_CACHE_TTL_MS=3000
PUBLIC_PRODUCT_CACHE_CONTROL=public, max-age=30, s-maxage=60, stale-while-revalidate=120
PUBLIC_PRODUCT_DETAIL_CACHE_CONTROL=public, max-age=60, s-maxage=120, stale-while-revalidate=300

# External API URLs
GEO_COUNTRIES_NOW_API=https://countriesnow.space/api/v0.1
GEO_ZIPPOPOTAM_API=https://api.zippopotam.us
GEO_GEONAMES_API=https://secure.geonames.org
GEONAMES_USERNAME=demo
GEO_POSTAL_PINCODE_API=https://api.postalpincode.in
YOUTUBE_THUMBNAIL_URL=https://img.youtube.com/vi
MAILERSEND_API_URL=https://api.mailersend.com/v1/email

# OAuth / auth callbacks
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5001/api/auth/google/callback

# Environment
NODE_ENV=development
