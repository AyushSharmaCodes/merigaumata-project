# Supabase Configuration
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters-long-change-this-in-production
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Email Service Configuration
# Provider options: mailersend | smtp | console
EMAIL_PROVIDER=mailersend

# MailerSend Configuration (when EMAIL_PROVIDER=mailersend)
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=Your App Name

# SMTP Configuration (when EMAIL_PROVIDER=smtp)
# Supports Gmail, Outlook, and custom SMTP servers
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME=Your App Name
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Application Configuration
APP_NAME=Antigravity
FRONTEND_URL=http://localhost:5173
PORT=5001
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# External API URLs
GEO_COUNTRIES_NOW_API=https://countriesnow.space/api/v0.1
GEO_ZIPPOPOTAM_API=https://api.zippopotam.us
GEO_GEONAMES_API=https://secure.geonames.org
GEONAMES_USERNAME=demo
GEO_POSTAL_PINCODE_API=https://api.postalpincode.in
YOUTUBE_THUMBNAIL_URL=https://img.youtube.com/vi
MAILERSEND_API_URL=https://api.mailersend.com/v1/email

# Environment
NODE_ENV=development