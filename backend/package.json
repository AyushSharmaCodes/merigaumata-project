{
    "name": "ecommerce-backend",
    "version": "1.0.0",
    "description": "Backend for Ecommerce Gaushala",
    "main": "server.js",
    "engines": {
        "node": ">=24 <25"
    },
    "scripts": {
        "start": "node server.js",
        "dev": "nodemon server.js",
        "test": "jest",
        "test:auth": "jest --testPathPattern=auth",
        "test:hardening": "jest --runInBand analytics-rbac.test.js contact-service.test.js comment-service.test.js upload-route-auth.test.js cron-auth.test.js testimonial-route-helpers.test.js contact-route-permissions.test.js coupon-route-permissions.test.js about-route-permissions.test.js gallery-carousel-route-permissions.test.js upload-delete-route-permissions.test.js returns-reviews-testimonials-route-permissions.test.js",
        "loadtest": "node ../scripts/load-test.js",
        "loadtest:health": "node ../scripts/load-test.js --path=/api/health --concurrency=50 --requests=1000",
        "loadtest:products": "node ../scripts/load-test.js --path=/api/products --concurrency=30 --requests=500",
        "loadtest:mixed": "node ../scripts/mixed-load-test.js --concurrency=30 --requests=300",
        "sync-locales": "node scripts/sync-locales.js",
        "ses:setup-config-set": "node scripts/ses-setup-configuration-set.js",
        "build": "echo 'Backend build complete'"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "dependencies": {
        "@aws-sdk/client-sesv2": "^3.1017.0",
        "@newrelic/pino-enricher": "^1.1.1",
        "@supabase/supabase-js": "^2.39.0",
        "bcryptjs": "^3.0.3",
        "cookie-parser": "^1.4.7",
        "cors": "^2.8.5",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "express-rate-limit": "^8.2.1",
        "google-translate-api-x": "^10.7.2",
        "handlebars": "^4.7.8",
        "helmet": "^8.1.0",
        "i18next": "^25.8.0",
        "i18next-fs-backend": "^2.6.1",
        "i18next-http-middleware": "^3.9.2",
        "isomorphic-dompurify": "^2.33.0",
        "jsonwebtoken": "^9.0.3",
        "mammoth": "^1.11.0",
        "multer": "^2.0.2",
        "newrelic": "^13.9.0",
        "node-cron": "^4.2.1",
        "nodemailer": "^8.0.5",
        "pdf-parse": "^2.4.5",
        "pino": "^10.1.0",
        "pino-abstract-transport": "^3.0.0",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "pino-roll": "^4.0.0",
        "puppeteer": "^24.35.0",
        "razorpay": "^2.9.6",
        "sharp": "^0.34.5",
        "uuid": "^13.0.0",
        "zod": "^3.25.76",
        "axios": "^1.13.2"
    },
    "devDependencies": {
        "jest": "^29.7.0",
        "nodemon": "^3.0.2"
    }
}
