# Supabase Configuration
# Note: Use the Connection Pooler URL (e.g., port 6543) instead of direct (e.g., port 5432) to prevent exhaustion in serverless or multi-node scenarios
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
SUPABASE_ANON_KEY=your_anon_key

# JWT
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# App / URLs
NODE_ENV=production
APP_NAME=Antigravity
PORT=5001
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=https://your-frontend-domain.com
TRUST_PROXY=true

# Web / Worker role
# Web nodes should keep these false.
# A single dedicated worker node can enable them.
ENABLE_INTERNAL_SCHEDULER=false
ENABLE_RESERVATION_CLEANUP=false

# Logging / invoice storage
LOG_PROVIDER=stdout
INVOICE_STORAGE_STRATEGY=SUPABASE

# Request / upload limits
JSON_BODY_LIMIT=10mb
URLENCODED_BODY_LIMIT=1mb
GENERIC_UPLOAD_FILE_SIZE_LIMIT_MB=10
ABOUT_TEAM_IMAGE_LIMIT_MB=5

# Cache tuning
PRODUCT_LIST_CACHE_TTL_MS=30000
CART_CACHE_TTL_MS=3000
CHECKOUT_SUMMARY_CACHE_TTL_MS=3000
PUBLIC_PRODUCT_CACHE_CONTROL=public, max-age=30, s-maxage=60, stale-while-revalidate=120
PUBLIC_PRODUCT_DETAIL_CACHE_CONTROL=public, max-age=60, s-maxage=120, stale-while-revalidate=300

# Tax / commerce
SELLER_STATE_CODE=27

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_API_TIMEOUT=30000

# Email provider
EMAIL_PROVIDER=mailersend
MAILERSEND_API_KEY=your_mailersend_api_key
MAILERSEND_FROM_EMAIL=noreply@yourdomain.com
MAILERSEND_FROM_NAME=Antigravity

# Optional SMTP fallback
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_smtp_username
SMTP_PASSWORD=your_smtp_password
SMTP_FROM_NAME=Antigravity
SMTP_FROM_EMAIL=noreply@yourdomain.com

# Geo / external APIs
GEO_COUNTRIES_NOW_API=https://countriesnow.space/api/v0.1
GEO_ZIPPOPOTAM_API=https://api.zippopotam.us
GEO_GEONAMES_API=https://secure.geonames.org
GEONAMES_USERNAME=your_geonames_username
GEO_POSTAL_PINCODE_API=https://api.postalpincode.in
YOUTUBE_THUMBNAIL_URL=https://img.youtube.com/vi
MAILERSEND_API_URL=https://api.mailersend.com/v1/email
