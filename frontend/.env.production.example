# Public frontend domain
VITE_FRONTEND_URL=https://yourdomain.com

# Backend/API domain
VITE_BACKEND_URL=https://api.yourdomain.com
VITE_API_URL=https://api.yourdomain.com/api

# Maps / embeds
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
VITE_GOOGLE_MAPS_EMBED_URL=https://maps.google.com/maps
VITE_GOOGLE_MAPS_SEARCH_URL=https://www.google.com/maps/search/

# Media / embeds
VITE_YOUTUBE_THUMBNAIL_URL=https://img.youtube.com/vi
VITE_YOUTUBE_EMBED_URL=https://www.youtube.com/embed
VITE_RAZORPAY_CHECKOUT_URL=https://checkout.razorpay.com/v1/checkout.js

# Public client-side keys
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional observability
VITE_SENTRY_DSN=
VITE_NEW_RELIC_LICENSE_KEY=
VITE_NEW_RELIC_APP_ID=
VITE_NEW_RELIC_ACCOUNT_ID=
VITE_NEW_RELIC_TRUST_KEY=

# Social profiles
VITE_SOCIAL_FACEBOOK_URL=https://facebook.com/your-page
VITE_SOCIAL_INSTAGRAM_URL=https://instagram.com/your-page
VITE_SOCIAL_TWITTER_URL=https://twitter.com/your-page

# Sharing URLs
VITE_SOCIAL_FACEBOOK_SHARE_URL=https://www.facebook.com/sharer/sharer.php
VITE_SOCIAL_TWITTER_SHARE_URL=https://twitter.com/intent/tweet
VITE_SOCIAL_LINKEDIN_SHARE_URL=https://www.linkedin.com/sharing/share-offsite/
VITE_SOCIAL_WHATSAPP_SHARE_URL=https://wa.me/

# External APIs
VITE_REST_COUNTRIES_API_URL=https://restcountries.com/v3.1
VITE_POSTAL_PINCODE_API_URL=https://api.postalpincode.in
VITE_CSC_API_URL=https://api.countrystatecity.in/v1
VITE_CSC_API_KEY=your_csc_api_key

VITE_APP_ENV=production
